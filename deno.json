{
  "nodeModulesDir": "manual",
  "tasks": {
    "dev": "vite",
    "dev:deno": "deno run -A --watch=static/,routes/ dev.ts",
    "build": "vite build",
    "start": "deno serve -A _fresh/server.js",
    "check": "deno fmt --check . && deno lint . && deno check **/*.ts"
  },
  "lint": {
    "rules": {
      "tags": ["fresh", "recommended"]
    }
  },
  "exclude": ["**/_fresh/*", "**/node_modules/*"],
  "imports": {
    "fresh": "jsr:@fresh/core@^2.2.0",
    "@fresh/plugin-vite": "jsr:@fresh/plugin-vite@^1.0.8",
    "preact": "npm:preact@^10.27.2",
    "@preact/signals": "npm:@preact/signals@^2.5.0",
    "vite": "npm:vite@^7.1.3"
  },
  "compilerOptions": {
    "jsx": "precompile",
    "jsxImportSource": "preact",
    "jsxPrecompileSkipElements": [
      "a", "img", "source", "body", "html", "head",
      "title", "meta", "script", "link", "style",
      "base", "noscript", "template"
    ],
    "types": ["vite/client"]
  }
}
